{
  "name": "@location-state/next",
  "version": "1.3.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": "https://github.com/recruit-tech/location-state",
  "description": "State management library for React that synchronizes with history entries supporting Next.js Pages Router and App Router.",
  "files": [
    "dist",
    "types",
    "src",
    "package.json"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "dev": "pnpm dev:build & pnpm dev:dts",
    "dev:build": "tsup src/index.ts --watch",
    "dev:dts": "tsc -p tsconfig.dts.json --watch",
    "build": "tsup src/index.ts",
    "dts": "tsc -p tsconfig.dts.json",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@location-state/core": "workspace:*"
  },
  "devDependencies": {
    "@location-state/core": "workspace:*",
    "@repo/configs": "workspace:*",
    "@repo/test-utils": "workspace:*",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "navigation-api-types": "0.6.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.2.0 || ^19.0.0"
  }
}
